# Conductor workspace collaboration dir + Phase -1 per-instance run artifacts
# (scaffolded repos, generated contract suites, service DBs, traces, results).
.context/

# Secrets — never commit (effector API keys are injected from the environment).
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local service databases produced by booted instances
*.db
*.sqlite
*.sqlite3

# T-1.3: live run ledgers stay OUT of git (a committed live ledger gets rewound by checkpoint/restore; the gitignored workdir is the durable source of truth)
experiments/phase_minus_1/results/**/*.records.jsonl
experiments/phase_minus_1/results/**/*.records.inflight
