# Conductor workspace collaboration dir + Phase -1 per-instance run artifacts
# (scaffolded repos, generated contract suites, service DBs, traces, results).
.context/

# Secrets — never commit (effector API keys are injected from the environment).
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local service databases produced by booted instances
*.db
*.sqlite
*.sqlite3
